# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL (lead storage) ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vitto

# ── MongoDB (OTP sessions) ────────────────────────────────
MONGO_URI=mongodb://localhost:27017/vitto

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ── OTP ───────────────────────────────────────────────────
# In production, integrate with MSG91 or similar
OTP_EXPIRY_MINUTES=10
# Set to 'true' in development to log OTPs to console
OTP_CONSOLE_LOG=true

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
